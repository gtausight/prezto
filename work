#### run themis from any directory with the below functions
# a common work flow is to run a terminal with themis in your project directory not in the Themis directory
run_shell_container() {
  pushd $THEMIS_DIR && task run-shell-container && popd
}

delete_shell_container() {
  pushd $THEMIS_DIR && task delete-shell-container && popd
}

create_cluster() {
  pushd $THEMIS_DIR && task create-cluster && popd
}

delete_cluster() {
  pushd $THEMIS_DIR && task delete-cluster && popd
}

nuke_themis() {
  read -p "Are you sure you want to nuke the cluster and shell container? (y/n) " -n 1 -r
  echo    # move to a new line
  if [[ $REPLY =~ ^[Yy]$ ]]
  then
    delete_shell_container
    delete_cluster
  fi
}

bootstrap_themis() {
  create_cluster
  run_shell_container
}

nukestrap_themis() {
  nuke
  bootstrap
}

update_themis() {
  delete_shell_container
  pushd $THEMIS_DIR && git checkout main && git pull
  run_shell_container
}

nuke_update_strap_themis() {
  nuke_themis
  update_themis
  bootstrap_themis
}

alias bsh="/opt/homebrew/bin/bash"

# Wrapper function for run_shell_container
rsc() {
  echo "[rsc] alias for run_shell_container."
  run_shell_container "$@"
}

# Wrapper function for run_shell_container
dsc() {
  echo "[dsc] alias for delete_shell_container."
  delete_shell_container "$@"
}

